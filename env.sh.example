# Copy to env.sh, set values locally, then chmod 600 env.sh.
# This template is safe to commit. env.sh is git-ignored.
export DB_HOST=''
export DB_PORT='3306'
# MySQL schema in which the function creates and writes the configured table.
export DB_NAME=''
# MySQL table in DB_NAME where Object Storage event records are stored.
export DB_TABLE=''
export DB_USER=''
export DB_PASSWORD=''
export OCIR_USERNAME=''
export OCIR_AUTH_TOKEN=''
export COMPARTMENT_ID=''
export VCN_NAME=''
# Set this private subnet OCID directly, or configure both VCN_NAME and
# SUBNET_NAME. The deployment will not select an arbitrary private subnet.
export SUBNET_ID=''
export SUBNET_NAME=''
# OCI Function name. deploy.sh uses this to generate the deployed func.yaml.
export FUNCTION_NAME=''
export APP_NAME=''
export REGION=''
export REGION_KEY=''
export REPOSITORY_PREFIX=''
# Optional; defaults to "${FUNCTION_NAME}-events".
export RULE_NAME=''
# Optional; defaults to a description derived from FUNCTION_NAME.
export RULE_DESCRIPTION=''
# Optional JSON array; defaults to Object Storage create, delete, and update.
export EVENT_TYPES_JSON=''
# Optional Object Storage bucket filter. Leave blank to receive events from all
# buckets in OBJECT_STORAGE_COMPARTMENT_ID.
export OBJECT_STORAGE_BUCKET_NAME=''
# Optional; defaults to COMPARTMENT_ID and must be the same compartment.
export OBJECT_STORAGE_COMPARTMENT_ID=''
# OCI Logging identifiers for ./showlog.sh. Enable Function Invocation Logs on
# the application (Monitoring > Logs) in COMPARTMENT_ID, then copy the OCIDs
# from the selected Log Group and its invocation Log details pages. These are
# not secrets.
# Keeping the search scoped to this log avoids a broad compartment log search.
export FUNCTION_LOG_GROUP_ID=''
export FUNCTION_LOG_ID=''
