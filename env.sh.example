# Copy to env.sh, set values locally, then chmod 600 env.sh.
# This template is safe to commit. env.sh is git-ignored.
export DB_HOST=''
export DB_PORT='3306'
# MySQL schema in which the function creates and writes object_event.
export DB_NAME=''
export DB_USER=''
export DB_PASSWORD=''
export OCIR_USERNAME=''
export OCIR_AUTH_TOKEN=''
export COMPARTMENT_ID=''
export VCN_NAME=''
export SUBNET_ID=''
# OCI Function name. deploy.sh uses this to generate the deployed func.yaml.
export FUNCTION_NAME=''
export APP_NAME=''
export REGION=''
export REGION_KEY=''
export REPOSITORY_PREFIX=''
# OCI Logging identifiers for ./showlog.sh. Enable Function Invocation Logs on
# the application (Monitoring > Logs) in COMPARTMENT_ID, then copy the OCIDs
# from the selected Log Group and its invocation Log details pages. These are
# not secrets.
# Keeping the search scoped to this log avoids a broad compartment log search.
export FUNCTION_LOG_GROUP_ID=''
export FUNCTION_LOG_ID=''
